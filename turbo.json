{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "storyboard.yaml"]
    },
    "build:types": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:main": {
      "dependsOn": ["build:types"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
