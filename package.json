{
  "name": "next-apps-template-internal",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/easyops-cn/next-apps-template-internal",
  "repository": {
    "type": "git",
    "url": "git@github.com:easyops-cn/next-apps-template-internal.git"
  },
  "license": "UNLICENSED",
  "scripts": {
    "prepare": "husky",
    "serve": "brick-container-serve",
    "start": "turbo run dev",
    "build": "turbo run build",
    "build:apps": "turbo run build --filter='./apps/*'",
    "build:apps:artifact": "pnpm --filter './apps/*' run build:artifact",
    "build:apps:artifact:production": "pnpm --filter './apps/*' run build:artifact:production",
    "build:bricks": "pnpm run build:bricks:types && pnpm run build:bricks:main",
    "build:bricks:types": "pnpm --filter './bricks/*' run build:types",
    "build:bricks:main": "pnpm --filter './bricks/*' run build:main",
    "build:shared": "turbo run build --filter='./shared/*'",
    "prebuild:bricks:main": "pre-build-next-bricks",
    "postbuild:bricks:main": "post-build-next-bricks",
    "postbuild:apps": "node scripts/postbuild/index.js",
    "test": "test-next-project",
    "test:apps": "NODE_OPTIONS=--experimental-vm-modules jest",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "release": "node scripts/version-and-release.js",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "@next-core/brick-container": "^3.24.10",
    "@next-core/brick-playground": "^1.16.5",
    "@next-core/build-next-bricks": "^1.26.2",
    "@next-core/build-next-libs": "^1.2.0",
    "@next-core/babel-preset-next": "^1.0.26",
    "@next-core/browserslist-config-next": "^1.1.2",
    "@next-core/test-next": "^2.0.0",
    "@next-core/eslint-config-next": "^3.0.1",
    "@next-core/yo": "^1.5.98",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "lint-staged": "^15.2.2",
    "typescript": "^5.4.5",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@types/lodash": "^4.17.21",
    "@types/history": "^4.7.11",
    "@types/js-yaml": "^3.12.10",
    "@types/node": "^20.12.7",
    "@changesets/cli": "^2.29.7",
    "husky": "^9.1.7",
    "@babel/runtime": "^7.28.4",
    "moment": "^2.30.1",
    "yaml": "^2.3.4",
    "cross-env": "^7.0.3",
    "concurrently": "^8.2.2",
    "@next-bricks/basic": "^1.58.1",
    "@next-bricks/containers": "^1.15.6",
    "@next-bricks/form": "^1.14.1",
    "@next-bricks/icons": "^1.5.4",
    "@next-bricks/illustrations": "^1.3.1",
    "@next-bricks/shoelace": "^1.1.2",
    "@next-bricks/v2-adapter": "^1.3.1",
    "@bricks/code-bricks": "^1.30.25"
  },
  "browserslist": {
    "development": [
      "extends @next-core/browserslist-config-next/development"
    ],
    "production": [
      "extends @next-core/browserslist-config-next/production"
    ]
  },
  "prettier": {
    "trailingComma": "es5"
  }
}
